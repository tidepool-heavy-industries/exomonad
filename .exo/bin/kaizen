#!/usr/bin/env bash
# Kaizen: ClickHouse-powered swarm analysis
#
# Usage:
#   kaizen                    # interactive clickhouse-client (if available)
#   kaizen "SELECT ..."       # one-shot query
#   kaizen summary            # shortcut for swarm_summary
#   kaizen agents             # shortcut for agent_lifecycles
#   kaizen prs                # shortcut for pr_pipeline
#   kaizen tools              # shortcut for tool_summary
#   kaizen reviews            # shortcut for copilot_reviews
#   kaizen tree               # shortcut for agent_tree
#   kaizen timeline           # shortcut for swarm_timeline
#   kaizen delivery           # shortcut for delivery_audit

CH_URL="http://localhost:8123"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
SQL_VIEWS_FILE="$SCRIPT_DIR/otel/kaizen-traces.sql"

# Check if ClickHouse is reachable
if ! curl -sf "$CH_URL/ping" > /dev/null; then
  echo "ClickHouse is not reachable at $CH_URL" >&2
  echo "Please start the OTel infrastructure:" >&2
  echo "  docker compose -f .exo/otel/docker-compose.yml up -d" >&2
  exit 1
fi

case "${1:-}" in
  summary)  QUERY="SELECT * FROM otel.swarm_summary" ;;
  agents)   QUERY="SELECT * FROM otel.agent_lifecycles ORDER BY spawned_at" ;;
  prs)      QUERY="SELECT * FROM otel.pr_pipeline ORDER BY filed_at" ;;
  tools)    QUERY="SELECT * FROM otel.tool_summary" ;;
  reviews)  QUERY="SELECT * FROM otel.copilot_reviews ORDER BY review_ts" ;;
  tree)     QUERY="SELECT * FROM otel.agent_tree" ;;
  timeline) QUERY="SELECT * FROM otel.swarm_timeline ORDER BY ts" ;;
  delivery) QUERY="SELECT * FROM otel.delivery_audit ORDER BY ts" ;;
  "")
    if command -v clickhouse-client >/dev/null 2>&1; then
      exec clickhouse-client --host localhost --port 9000 --database otel
    else
      echo "Interactive mode requires clickhouse-client. Use shortcuts instead:"
      echo "  summary, agents, prs, tools, reviews, tree, timeline, delivery"
      exit 0
    fi
    ;;
  *)        QUERY="$1" ;;
esac

# Prepend views and append format. 
# ClickHouse HTTP API executes multiple semicolon-separated queries in one request 
# and returns the result of the last one.
{
  cat "$SQL_VIEWS_FILE"
  echo "$QUERY FORMAT PrettyCompact;"
} | curl -sS "$CH_URL" --data-binary @-
